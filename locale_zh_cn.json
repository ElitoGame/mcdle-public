    "about": {
      "title": "介绍",
      "button_title": "介绍",
      "intro": "MC猜猜乐（Mcdle）以《我的世界》为题材，每天随机选择一个方块、物品和生物，玩家需要猜测正确答案。每天打开链接，看看你能连续猜对几天！游戏支持社交分享功能，快把连对记录分享给朋友吧。",
      "help_pointer": "不知道怎么玩？进入不同玩法的页面，标题下都有“？”图标，点击即可打开帮助菜单，查看当前模式的示例玩法和详细说明。",
      "suggestions": {
        "title": "建议与交流",
        "description": {
          "pre_link": "大部分建议和问题反馈都会在",
          "link": "Discord",
          "post_link": "上处理，快来加入聊天吧，还有游戏小彩蛋噢！我们有专门的频道来讨论今天的谜题，还可以分享你的连胜记录！"
        }
      },
      "support": {
        "title": "支持我们",
        "description": {
          "pre_link": "如果你想支持这个项目（比如支付域名费用、支持新功能等），可以看看我的",
          "link": "Ko-fi",
          "post_link": "页面!"
        }
      },
      "credits": {
        "title": "鸣谢",
        "description": {
          "pre_link": "游戏的数据来自",
          "link": "Minecraft Wiki",
          "post_link": "。很多图片也来自 Minecraft Wiki，感谢他们一直以来的整理与更新！MCdle 是一个非官方项目，与 Mojang Studios 没有官方关联。游戏基于minecraft，玩法灵感来自 Wordle 和 LoLdle。"
        },
        "credit_list": {
          "kineticraft": {
            "pre_link": "感谢服务器",
            "link": "kineticraft.net",
            "post_link": "提供背景图！"
          },
          "vanilla_tweaks": {
